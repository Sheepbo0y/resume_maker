datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  resumes   ResumeDraft[]
}

model ResumeDraft {
  id        Int    @id @default(autoincrement())
  userId    Int
  user      User   @relation(fields: [userId], references: [id])
  title     String?
  // Store the full JSON Resume as a single JSON field
  resumeJson String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
